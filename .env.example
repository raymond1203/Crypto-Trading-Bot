# CryptoSentinel Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================================
# Binance API
# ============================================================
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
# Testnet (개발용)
BINANCE_TESTNET=true
BINANCE_TESTNET_API_KEY=your_testnet_key
BINANCE_TESTNET_API_SECRET=your_testnet_secret

# ============================================================
# AWS
# ============================================================
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=your_account_id
AWS_PROFILE=cryptosentinel

# ============================================================
# Telegram Bot
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================
# Model Config
# ============================================================
RANDOM_SEED=42
MODEL_CONFIG_PATH=configs/model_config.yaml
TRADING_CONFIG_PATH=configs/trading_config.yaml

# ============================================================
# Sentiment Analysis (CryptoBERT + FinBERT, 로컬 실행)
# ============================================================
SENTIMENT_PROVIDER=dual
CRYPTO_MODEL=ElKulako/cryptobert
FIN_MODEL=ProsusAI/finbert
