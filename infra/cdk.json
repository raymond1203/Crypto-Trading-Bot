{
  "app": "npx ts-node --prefer-ts-exts bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "node_modules",
      "dist"
    ]
  },
  "context": {
    "environments": {
      "dev": {
        "envName": "dev",
        "account": "",
        "region": "ap-northeast-2"
      },
      "prod": {
        "envName": "prod",
        "account": "",
        "region": "ap-northeast-2"
      }
    }
  }
}
